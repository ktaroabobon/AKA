    "dotenv": "^17.4.2",
    "hono": "^4.6.13",
    "pino": "^9.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "pino-pretty": "^13.0.0",
    "vitest": "^4.1.7"
  }
